# Production — Azure SQL
# Copy this file to .env.production.local and fill in real values
SQL_SERVER=millets-momo-sql.database.windows.net
SQL_DATABASE=millets-momo-db
SQL_USER=momoadmin
SQL_PASSWORD=<your-production-password>
SQL_PORT=1433
SQL_ENCRYPT=true
SQL_TRUST_CERT=false
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRY=12h
ALLOWED_ORIGIN=https://millets-momo-swa.azurestaticapps.net
NODE_ENV=production