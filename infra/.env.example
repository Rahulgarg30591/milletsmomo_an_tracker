# Deployment Configuration
# Copy this file to .env and fill in values. The .env file is gitignored.
#
# SQL-only deploy:
#   cp infra/.env.example infra/.env
#   bash infra/deploy-sql.sh
#
# Full deploy (SQL + SWA):
#   bash infra/deploy.sh

# --- Resource Group ---
RG_NAME=millets-momo-rg
LOCATION=centralindia
BASE_NAME=millets-momo

# --- SQL Database ---
# Admin username for Azure SQL Server
SQL_ADMIN_USER=momoadmin

# Admin password (min 8 chars, must contain upper, lower, digit, symbol)
# Leave empty to auto-generate on first deploy
SQL_ADMIN_PASSWORD=

# Database name (defaults to ${BASE_NAME}-db)
SQL_DB_NAME=millets-momo-db

# --- Auth (needed for full deploy) ---
# JWT secret for API tokens. Leave empty to auto-generate on first deploy
JWT_SECRET=

# --- SWA / GitHub (needed for full deploy) ---
# GitHub repo in owner/repo format (e.g. "myorg/millets-momo")
REPO_URL=

# GitHub PAT with repo access. Required for SWA CI/CD
REPOSITORY_TOKEN=

# Git branch to deploy
BRANCH=main

# --- CORS (needed for full deploy) ---
# Allowed origin for CORS. Leave empty to auto-detect from SWA hostname
ALLOWED_ORIGIN=

# --- SQL Firewall ---
# Your public IP for SQL firewall rule. Leave empty to auto-detect
CLIENT_IP=